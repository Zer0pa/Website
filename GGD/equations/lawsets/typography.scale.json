      "lhs": "section_title",
      "op": "between",
      "rhs": [
        27,
        28
      ],
      "severity": "MAJOR"
    },
    {
      "id": "typography.eyebrow.range",
      "lhs": "eyebrow",
      "op": "between",
      "rhs": [
        13,
        14
      ],
      "severity": "MINOR"
    },
    {
      "id": "typography.display.gt_section_title",
      "lhs": "display",
      "op": "gt",
      "rhs": "section_title",
      "severity": "MAJOR"
