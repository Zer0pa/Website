{
  "id": "typography.scale",
  "constants": {
    "body_base": 16,
    "desktop_ratio": 1.2,
    "mobile_ratio": 1.125
  },
  "derived": {
    "display": "round(modular_scale(body_base, 5, desktop_ratio), 2)",
    "section_title": "round(modular_scale(body_base, 3, desktop_ratio), 2)",
    "eyebrow": "round(modular_scale(body_base, -1, desktop_ratio), 2)",
    "mobile_display": "round(modular_scale(body_base, 5, mobile_ratio), 2)"
  },
  "constraints": [
    {
      "id": "typography.body_base.eq",
      "lhs": "body_base",
