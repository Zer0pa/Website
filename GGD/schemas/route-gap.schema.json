{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GGD Route Gap",
  "type": "object",
  "required": [
    "version",
    "id",
    "route",
    "route_role",
    "kind",
    "status",
    "source_handoff",
    "severity_counts",
    "summary"
  ],
  "properties": {
    "version": { "type": "integer" },
    "id": { "type": "string" },
    "route": { "type": "string" },
    "route_role": { "type": "string" },
    "kind": { "type": "string" },
    "status": { "type": "string" },
    "source_handoff": { "type": "string" },
    "cycle_id": { "type": ["string", "null"] },
    "phase_id": { "type": ["string", "null"] },
    "lane": { "type": ["string", "null"] },
    "hypothesis": { "type": ["string", "null"] },
    "summary": { "type": ["string", "null"] },
    "severity_counts": {
      "type": "object",
      "required": ["critical", "major", "minor", "note"],
      "properties": {
        "critical": { "type": "integer" },
        "major": { "type": "integer" },
        "minor": { "type": "integer" },
        "note": { "type": "integer" }
      }
    },
    "top_drift_surfaces": {
      "type": "array",
      "items": { "type": "string" }
    },
    "flagship_invariants_intact": { "type": "boolean" },
    "responsive_integrity": { "type": "object" },
    "quality_findings_summary": { "type": ["string", "null"] },
    "recommendation": { "type": ["string", "null"] },
    "next_hypothesis": { "type": ["string", "null"] },
    "rollback_target": { "type": ["string", "null"] },
    "evidence_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "learning_captured": {
      "type": "array",
      "items": { "type": "string" }
    },
    "commands_run": {
      "type": "array",
      "items": { "type": "string" }
    },
    "known_risks": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
