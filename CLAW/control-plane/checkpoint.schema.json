{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CLAW Integration Checkpoint",
  "type": "object",
  "required": [
    "checkpoint_id",
    "phase",
    "source_commits",
    "rollback_point",
    "qa_verdict",
    "status",
    "created_at"
  ],
  "properties": {
    "checkpoint_id": { "type": "string" },
    "phase": { "type": "string" },
    "cycle_id": {
      "type": ["string", "null"]
    },
    "source_commits": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rollback_point": { "type": "string" },
    "qa_verdict": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": ["accepted", "rejected", "superseded"]
    },
    "full_qa_bundle": {
      "type": ["string", "null"]
    },
    "recovery_verdict": {
      "type": ["string", "null"]
    },
    "open_blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "best_known_state": {
      "type": ["string", "null"]
    },
    "created_at": { "type": "string" }
  },
  "additionalProperties": false
}
