{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CLAW QA Verdict",
  "type": "object",
  "required": [
    "candidate_commit",
    "build",
    "parser",
    "layout",
    "responsive",
    "law_compliance",
    "recommendation"
  ],
  "properties": {
    "candidate_commit": { "type": "string" },
    "build": { "type": "string" },
    "parser": { "type": "string" },
    "layout": {
      "type": "object",
      "additionalProperties": true
    },
    "responsive": {
      "type": "object",
      "additionalProperties": true
    },
    "law_compliance": {
      "type": "object",
      "additionalProperties": true
    },
    "regression_delta": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "recommendation": {
      "type": "string",
      "enum": ["accept", "reject", "hold"]
    }
  },
  "additionalProperties": false
}
