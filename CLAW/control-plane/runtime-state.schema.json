{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Website-main Autonomous Control State",
  "type": "object",
  "required": [
    "version",
    "project",
    "mode",
    "press_go",
    "current_milestone",
    "current_phase",
    "active_wave",
    "lanes",
    "latest_audits",
    "blockers",
    "next_actions",
    "stop_conditions"
  ],
  "properties": {
    "version": {
      "type": "integer"
    },
    "project": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "press_go": {
      "type": "boolean"
    },
    "current_milestone": {
      "type": "string"
    },
    "current_phase": {
      "type": "string"
    },
    "active_wave": {
      "type": "string"
    },
    "control_style": {
      "type": "string"
    },
    "latest_wave_report": {
      "type": [
        "string",
        "null"
      ]
    },
    "phase_plan": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_manifest": {
      "type": [
        "string",
        "null"
      ]
    },
    "execution_prd": {
      "type": [
        "string",
        "null"
      ]
    },
    "execution_plan": {
      "type": [
        "string",
        "null"
      ]
    },
    "hardening_artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ]
      }
    },
    "active_cadence_profile": {
      "type": [
        "string",
        "null"
      ]
    },
    "run_window": {
      "type": "object",
      "additionalProperties": true
    },
    "lanes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "latest_audits": {
      "type": "object",
      "additionalProperties": true
    },
    "current_scores": {
      "type": "object",
      "additionalProperties": true
    },
    "gates": {
      "type": "object",
      "additionalProperties": true
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "learning_backlog": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "queue": {
      "type": "object",
      "additionalProperties": true
    },
    "active_jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "locks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "current_checkpoint": {
      "type": [
        "string",
        "null"
      ]
    },
    "rollback_checkpoint": {
      "type": [
        "string",
        "null"
      ]
    },
    "pause_requested": {
      "type": "boolean"
    },
    "stop_requested": {
      "type": "boolean"
    },
    "heartbeat_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "retry_budget": {
      "type": "object",
      "additionalProperties": true
    },
    "active_cycle": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "last_recovery_event": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_health_check": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
