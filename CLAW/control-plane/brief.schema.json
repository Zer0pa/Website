    "job_id": { "type": "string" },
    "lane": { "type": "string" },
    "phase": { "type": "string" },
    "target": { "type": "string" },
    "objective": { "type": "string" },
    "writes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
