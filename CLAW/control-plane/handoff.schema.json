{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CLAW Lane Handoff",
  "type": "object",
  "required": [
    "cycle_id",
    "job_id",
    "lane",
    "phase",
    "target",
    "hypothesis",
    "status",
    "files_changed",
    "commands_run",
    "preflight_baseline",
    "postflight_metrics",
    "known_risks",
    "recommendation",
    "learning_captured"
  ],
  "properties": {
    "cycle_id": { "type": "string" },
    "job_id": { "type": "string" },
    "lane": { "type": "string" },
    "phase": { "type": "string" },
    "target": { "type": "string" },
    "hypothesis": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["accepted", "rejected", "hold", "escalated"]
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "commands_run": {
      "type": "array",
      "items": { "type": "string" }
    },
    "preflight_baseline": {
      "type": "object",
      "additionalProperties": true
    },
    "postflight_metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "audit_result": {
      "type": ["object", "string", "null"]
    },
    "known_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommendation": { "type": "string" },
    "next_hypothesis": {
      "type": ["string", "null"]
    },
    "rollback_target": {
      "type": ["string", "null"]
    },
    "learning_captured": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
